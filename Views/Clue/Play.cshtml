@model ClueGame.Models.Game

@{
    var humanPlayer = Model.Players.First(p => p.CharacterCardId == Model.HumanCharacterId);
    var playerTitle = humanPlayer.Name.Split()[0];
    var playerSurname = humanPlayer.Name.Split()[1];
    var allRooms = ViewBag.Rooms as List<ClueGame.Models.Card>;
    var adjacentRooms = ViewBag.AdjacentRooms as List<ClueGame.Models.Card>;
    var adjacentRoomIds = adjacentRooms.Select(r => r.Id).ToHashSet();
    var isHumanTurn = Model.CurrentTurnPlayerId == humanPlayer.Id;
    var secretPassagePairs = new HashSet<(string, string)> {
        ("Kitchen", "Study"), ("Study", "Kitchen"),
        ("Conservatory", "Lounge"), ("Lounge", "Conservatory")
    };
}

<div class="map-section">
<div class="player-character-panel">

    <div class="player-identity">
        <img src="~/images/characters/@Model.HumanCharacter.ImageFileName" alt="@Model.HumanCharacter.Name" class="portrait-small" />
        <h4>@Model.HumanCharacter?.Name</h4>
    </div>

    <div class="player-hand">
        <h4>Your Cards</h4>
        <div class="card-grid">
            @foreach (var card in humanPlayer.Cards.Select(c => c.Card))
            {
                <div class="card-item">
                    @switch (@card.Type)
                    {
                        case ClueGame.Models.Enums.CardType.Suspect:
                            <img src="~/images/characters/@card.ImageFileName" alt="@card.Name" />
                            break;
                        case ClueGame.Models.Enums.CardType.Weapon:
                            <img src="~/images/weapons/@card.ImageFileName" alt="@card.Name" />
                            break;
                        case ClueGame.Models.Enums.CardType.Room:
                            <img src="~/images/rooms/@card.ImageFileName" alt="@card.Name" />
                            break;
                    }
                    <h5>@card.Name</h5>
                </div>
            }
        </div>
    </div>
</div>

<div class="board-map">
    @foreach (var room in allRooms)
    {
        var roomSlug = room.Name.Replace(" ", "").Replace(".", "").ToLower();
        var isCurrentRoom = room.Id == humanPlayer.PlayerRoomId;
        var isAdjacent = adjacentRoomIds.Contains(room.Id);
        var isSecretPassage = isAdjacent && secretPassagePairs.Contains((humanPlayer.PlayerRoom.Name, room.Name));
        var playersInRoom = Model.Players.Where(p => p.PlayerRoomId == room.Id).ToList();

        <div class="room-tile room-@roomSlug @(isCurrentRoom ? "current-room" : "") @(isAdjacent ? "adjacent-room" : "")">
            <img src="~/images/rooms/@room.ImageFileName" alt="@room.Name" />
            <span class="room-label">@room.Name @(isSecretPassage ? "🔑" : "")</span>

            @if (playersInRoom.Any())
            {
                <div class="room-tokens">
                    @foreach (var player in playersInRoom)
                    {
                        <img src="~/images/characters/@player.CharacterCard.ImageFileName"
                             alt="@player.CharacterCard.Name"
                             class="player-token @(player.CharacterCardId == Model.HumanCharacterId ? "human-token" : "npc-token")"
                             title="@player.CharacterCard.Name" />
                    }
                </div>
            }

            @if (isAdjacent && isHumanTurn)
            {
                <form method="post" asp-action="MoveRoom" class="move-form">
                    <input type="hidden" name="gameId" value="@Model.Id" />
                    <input type="hidden" name="targetRoomId" value="@room.Id" />
                    <button type="submit" class="move-btn">Move Here</button>
                </form>
            }
        </div>
    }
    <div class="room-tile room-center">
        @if (Model.CurrentTurnPlayerId == humanPlayer.Id)
        {
            <div class="center-accusation">
                <h3>Make an Accusation</h3>
                <form method="post" asp-action="SubmitGuess">
                    <input type="hidden" name="gameId" value="@ViewBag.GameId" />
                    <input type="hidden" name="roomId" value="@humanPlayer.PlayerRoomId" />

                    <div class="form-group">
                        <label><strong>Suspect:</strong></label>
                        <select name="suspectId">
                            @foreach (var s in ViewBag.Suspects)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label><strong>Weapon:</strong></label>
                        <select name="weaponId">
                            @foreach (var w in ViewBag.Weapons)
                            {
                                <option value="@w.Id">@w.Name</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">Accuse!</button>
                </form>
            </div>
        }
        else
        {
            <span class="center-label">Clue</span>
        }
    </div>
</div>
<div class="guesses-panel">
        <h3>Past Guesses</h3>
        <table class="guess-history">
            <tr>
                <th>Time</th>
                <th>Player</th>
                <th>Suspect</th>
                <th>Weapon</th>
                <th>Room</th>
                <th>Correct?</th>
                <th>Disproved By Player</th>
                <th>Disproved By Card</th>
            </tr>
            @foreach (var a in Model.Accusations.OrderByDescending(a => a.Timestamp))
            {
                <tr>
                    <td>@a.Timestamp.ToShortTimeString()</td>
                    <td>@a.AccusingPlayer.Name</td>
                    <td>@a.SuspectCard?.Name</td>
                    <td>@a.WeaponCard?.Name</td>
                    <td>@a.RoomCard?.Name</td>
                    <td>@(a.IsCorrect ? "✔️" : "❌")</td>
                    <td>
                        @if (a.DisprovingPlayer != null)
                        {
                            <span>@a.DisprovingPlayer.CharacterCard.Name</span>
                        }
                        else
                        {
                            <span>n/a</span>
                        }
                    </td>
                    <td>
                        @if (a.DisprovingCard != null)
                        {
                            <span>@(a.AccusingPlayerId == humanPlayer.Id ? a.DisprovingCard.Name : "?")</span>
                        }
                        else
                        {
                            <span>n/a</span>
                        }
                    </td>
                </tr>
            }
        </table>

    </div>
</div>
</div>

@if (ViewBag.TurnEvents != null)
{
    var turnEvents = ViewBag.TurnEvents as List<string>;
    var isCorrect = (bool)ViewBag.AccusationCorrect;
    <div class="turn-summary-overlay">
        <div class="turn-summary-modal @(isCorrect ? "modal-correct" : "modal-wrong")">
            <h3 class="turn-summary-title">@(isCorrect ? "Case Solved!" : "Turn Summary")</h3>
            <ul class="turn-events">
                @foreach (var evt in turnEvents!)
                {
                    <li>@evt</li>
                }
            </ul>
            <a href="/Clue/Play?gameId=@ViewBag.GameId" class="btn btn-primary">Continue</a>
        </div>
    </div>
}
